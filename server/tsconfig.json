{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "ESNext",
      "dom"
    ],
    "typeRoots": [
      "@types",
      "node_modules/@types"
    ],
    "rootDir": "src",
    "baseUrl": "src",
    "outDir": "dist",
    "composite": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}